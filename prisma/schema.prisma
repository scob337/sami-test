generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum PatternType {
  ASSERTIVE   // الحازمة
  PRECISE     // المدققة
  CALM        // الهادئة
  WISE        // الحكيمة
  SPONTANEOUS // العفوية
  OPEN        // المنفتحة
  THINKER     // المفكرة
}

enum AttemptStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id          Int        @id @default(autoincrement())
  name        String?
  phone       String?    @unique
  email       String?    @unique
  avatarUrl   String?
  isAdmin     Boolean    @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())

  otpCodes    OtpCode[]
  attempts    Attempt[]
  payments    Payment[]
  comments    Comment[]
  ratings     Rating[]
  courses     UserCourse[]
  chatSessions ChatSession[]
  messages    Message[]
  episodeProgress UserEpisodeProgress[]
  notifications   UserNotification[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?  @db.Text
  filePdf     String   // URL to PDF
  price       Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tests     Test[]
  payments  Payment[]
}

model Test {
  id             Int      @id @default(autoincrement())
  name           String
  slug           String   @unique
  description    String?  @db.Text
  book           Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId         Int
  isActive       Boolean  @default(true)
  seoTitle       String?
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  createdAt      DateTime @default(now())

  questions Question[]
  attempts  Attempt[]
  aiPrompts AiPrompt[]
  payments  Payment[]
}

model AiPrompt {
  id           Int      @id @default(autoincrement())
  test         Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId       Int
  systemPrompt String   @db.Text
  reportRules  String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OtpCode {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

model Question {
  id           Int              @id @default(autoincrement())
  test         Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId       Int
  questionText String
  sortOrder    Int              @default(0)
  isActive     Boolean          @default(true)

  options      QuestionOption[]
  answers      Answer[]
}

model QuestionOption {
  id         Int           @id @default(autoincrement())
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId Int
  optionText String
  sortOrder  Int           @default(0)

  scores     OptionScore[]
  answers    Answer[]
}

model OptionScore {
  id        Int         @id @default(autoincrement())
  option    QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId  Int
  pattern   PatternType
  score     Int
}

model Attempt {
  id          Int        @id @default(autoincrement())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  test        Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      Int
  startedAt   DateTime   @default(now())
  completedAt DateTime?
  status      AttemptStatus @default(IN_PROGRESS)

  answers     Answer[]
  result      Result?
  payment     Payment?
}

model Answer {
  id         Int           @id @default(autoincrement())
  attempt    Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId  Int
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId Int
  option     QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId   Int
}

model Result {
  id              Int       @id @default(autoincrement())
  attempt         Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId       Int       @unique
  primaryPattern  PatternType
  secondaryPattern PatternType?
  scoresJson      Json
  createdAt       DateTime  @default(now())

  report          Report?
}

model Report {
  id         Int     @id @default(autoincrement())
  result     Result  @relation(fields: [resultId], references: [id], onDelete: Cascade)
  resultId   Int     @unique
  reportText String  @db.Text
  createdAt  DateTime @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    Int?
  test      Test?    @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId    Int?
  attempt   Attempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId Int?     @unique
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int?
  amount    Float
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])
  discountCodeId Int?
  createdAt DateTime @default(now())
}

model Course {
  id               Int       @id @default(autoincrement())
  title            String
  slug             String    @unique
  description      String?   @db.Text
  image            String?   // Main Thumbnail
  introVideoUrl    String?   // Free Intro Video
  introThumbnailUrl String?  // Intro Video Thumbnail
  videoUrl720      String?   // 720p Intro Video
  videoUrl1080     String?   // 1080p Intro Video
  price            Float     @default(0)
  isActive         Boolean   @default(true)
  seoTitle         String?
  seoDescription   String?   @db.Text
  seoKeywords      String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  episodes      Episode[]
  ratings       Rating[]
  enrollments   UserCourse[]
  payments      Payment[]
  discountCodes DiscountCode[]
}

model Episode {
  id          Int      @id @default(autoincrement())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    Int
  title       String
  slug        String?  // Realistic URL name
  description String?  @db.Text
  videoUrl    String   // Direct link
  videoUrl720 String?  // 720p link
  videoUrl1080 String? // 1080p link
  thumbnail   String?  // Episode Thumbnail
  duration    String?  // Video duration (e.g. "10:25")
  sortOrder   Int      @default(0)
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())

  comments    Comment[]
  ratings     Rating[]
  progress    UserEpisodeProgress[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  episodeId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Rating {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int?
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  episodeId Int?
  value     Int      // 1-5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model UserCourse {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model ChatSession {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Message {
  id            Int         @id @default(autoincrement())
  sessionId     Int
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId      Int
  sender        User        @relation(fields: [senderId], references: [id])
  content       String      @db.Text
  fileUrl       String?
  fileType      String?     // 'image' or 'video'
  isAdmin       Boolean     @default(false)
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([sessionId])
  @@index([senderId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  type      String   @default("info") // info, warning, success
  link      String?  // Optional click-through URL
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     UserNotification[]
}

model UserNotification {
  id             Int          @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId Int
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([userId, notificationId])
}

model DiscountCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  discount  Float    // Percentage or fixed amount
  type      String   @default("PERCENT") // PERCENT, FIXED
  courseId  Int?
  course   Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  payments  Payment[]
}

model UserEpisodeProgress {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  episodeId Int
  isWatched Boolean  @default(false)
  lastPos   Int?     // Last watched position in seconds
  updatedAt DateTime @updatedAt

  @@unique([userId, episodeId])
}
